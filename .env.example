# === Required for Video Editor ===
ANTHROPIC_API_KEY=sk-ant-...

# === Required for Thumbnail Generator ===
NANO_BANANA_API_KEY=your_gemini_api_key_here

# === Required for Outlier Detector (TubeLab) ===
TUBELAB_API_KEY=your_tubelab_key_here

# === Optional: Transcript fallback ===
APIFY_API_TOKEN=your_apify_token_here

# === Optional: YouTube upload via Auphonic ===
AUPHONIC_API_KEY=your_auphonic_key_here
AUPHONIC_PRESET_UUID=your_preset_uuid_here
YOUTUBE_SERVICE_UUID=your_youtube_service_uuid_here

# === Optional: Google Sheets (for outlier detector) ===
# Place credentials.json (OAuth or service account) in project root
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json
