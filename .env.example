# === Required for Video Editor ===
ANTHROPIC_API_KEY=sk-ant-...

# === Required for Thumbnail Generator ===
# Google Gemini API key — get one at https://aistudio.google.com/apikey
NANO_BANANA_API_KEY=your_gemini_api_key_here

# === Optional: GPT Image 1.5 (OpenAI alternate image model) ===
# Only needed if you want the GPT Image 1.5 toggle to work.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# === Production only (leave blank for local dev) ===
# Shared password gating the web UI. When blank, auth is disabled.
# Render injects this via the dashboard — do NOT commit a real password.
APP_PASSWORD=
# Username for basic auth (optional — defaults to "tikscale")
APP_USERNAME=tikscale
# Cap concurrent generations on small hosts (Render starter = 2)
THUMB_CONCURRENCY=999

# === Required for Outlier Detector (TubeLab) ===
TUBELAB_API_KEY=your_tubelab_key_here

# === Optional: Transcript fallback ===
APIFY_API_TOKEN=your_apify_token_here

# === Optional: YouTube upload via Auphonic ===
AUPHONIC_API_KEY=your_auphonic_key_here
AUPHONIC_PRESET_UUID=your_preset_uuid_here
YOUTUBE_SERVICE_UUID=your_youtube_service_uuid_here

# === Optional: Google Sheets (for outlier detector) ===
# Place credentials.json (OAuth or service account) in project root
# GOOGLE_APPLICATION_CREDENTIALS=credentials.json
